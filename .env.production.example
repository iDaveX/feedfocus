#
# FeedFocus — production env (Vercel) example (NO SECRETS)
#
# Add these in: Vercel → Project → Settings → Environment Variables
#

# Supabase (server-side)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM (Groq)
GROQ_API_KEY=

# Demo / public browser testing (optional)
# If you want people to test via a normal browser (not inside Telegram),
# set this to a numeric Telegram user id and DO NOT set TELEGRAM_BOT_TOKEN.
DEV_TELEGRAM_USER_ID=

# Optional (recommended)
DAILY_ANALYZE_LIMIT=30
MAX_FEEDBACK_ITEMS=50
RETENTION_DAYS=30

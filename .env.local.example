#
# FeedFocus — local dev env template
#
# Copy:
#   cp .env.local.example .env.local
#

#
# Web SaaS auth (no Telegram)
#
# Optional: fixed user id for demos (all visitors share one user).
DEV_USER_ID=

#
# Supabase (server-side only)
#
# Required. Create a Supabase project and take:
# - SUPABASE_URL: Project Settings → API → Project URL
# - SUPABASE_SERVICE_ROLE_KEY: Project Settings → API → service_role key
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

#
# LLM (Groq / OpenAI)
#
# Required for the main MVP scenario (Analyze).
#
# Default: Groq (OpenAI-compatible API)
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

#
# Limits (optional)
#
DAILY_ANALYZE_LIMIT=5
MAX_FEEDBACK_ITEMS=200
RETENTION_DAYS=30

#
# Client-exposed (optional)
#
NEXT_PUBLIC_MAX_FEEDBACK_ITEMS=200
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

#
# Ops (optional)
#
# If you want to use GET /api/cron/purge, set a secret and call:
#   /api/cron/purge?secret=...
CRON_SECRET=
